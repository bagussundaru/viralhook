# =============================================================================
# VIRALHOOK.ID — Environment Variables
# Salin file ini menjadi .env.local untuk development
# JANGAN PERNAH commit file .env atau .env.local ke git!
# =============================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Database ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://viralhook:PASSWORD@localhost:5432/viralhook_db

# --- Auth (better-auth) ---
# Generate dengan: openssl rand -base64 32
BETTER_AUTH_SECRET=your-super-secret-key-here-at-least-32-chars

# --- Google OAuth ---
# Buat di: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- AI / Agent Router (OpenRouter-compatible) ---
AGENT_ROUTER_API_KEY=your-agent-router-api-key
AGENT_ROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Midtrans Payment ---
# Ambil dari: https://dashboard.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
# Gunakan "sandbox" untuk testing, "production" untuk live
MIDTRANS_ENV=sandbox

# --- Modal.com (Serverless GPU) ---
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret

# --- Blaxel AI (Agent Orchestration) ---
BLAXEL_API_KEY=your-blaxel-api-key

# --- Email (opsional, untuk notifikasi) ---
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@viralhook.id
